{
  "manifest_version": 3,
  "name": "YTMusic Stay",
  "version": "1.0.0",
  "description": "Keeps YouTube Music in the bottom player — blocks auto-navigation to song pages and removes the album art overlay.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://music.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
